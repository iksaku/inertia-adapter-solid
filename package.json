{
  "name": "inertia-adapter-solid",
  "version": "1.0.0-beta.6",
  "license": "MIT",
  "description": "The SolidJS adapter for Inertia.js",
  "contributors": [
    "Jorge González <yo@jorgeglz.io>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iksaku/inertia-adapter-solid.git"
  },
  "bugs": {
    "url": "https://github.com/iksaku/inertia-adapter-solid/issues"
  },
  "files": [
    "dist",
    "types"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./types/server.d.ts",
      "import": "./dist/server.js"
    },
    "./vite": {
      "types": "./types/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "typesVersions": {
    "*": {
      "server": [
        "types/server.d.ts"
      ],
      "vite": [
        "types/vite.d.ts"
      ]
    }
  },
  "scripts": {
    "prebuild": "pnpm run clean",
    "build": "./build.js",
    "postbuild": "tsc",
    "build:with-deps": "pnpm build --with-deps",
    "clean": "rm -rf dist types",
    "dev": "pnpx concurrently -c \"#ffcf00,#3178c6\" \"pnpm dev:build\" \"pnpm dev:types\" --names build,types",
    "dev:build": "./build.js --watch",
    "dev:types": "tsc --watch --preserveWatchOutput",
    "es2022-check": "pnpm build:with-deps && es-check es2022 \"dist/index.js\" --checkFeatures --module --noCache --verbose",
    "prepublish": "pnpm run build"
  },
  "dependencies": {
    "@inertiajs/core": "^3.1.1",
    "@solid-primitives/deep": "^0.3.5",
    "@solid-primitives/memo": "^1.4.5",
    "es-toolkit": "^1.46.1",
    "laravel-precognition": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.31.0",
    "@inertiajs/vite": "^3.1.1",
    "@solidjs/meta": "^0.29.4",
    "es-check": "^9.6.4",
    "esbuild": "^0.28.0",
    "esbuild-node-externals": "^1.22.0",
    "solid-js": "^1.9.13",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@solidjs/meta": "^0.29.4",
    "solid-js": "^1.9.13"
  }
}
