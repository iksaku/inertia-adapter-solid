{
  "name": "inertia-adapter-solid",
  "version": "1.0.0-beta.5",
  "license": "MIT",
  "description": "The SolidJS adapter for Inertia.js",
  "contributors": [
    "Jorge González <yo@jorgeglz.io>"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/iksaku/inertia-adapter-solid.git"
  },
  "bugs": {
    "url": "https://github.com/iksaku/inertia-adapter-solid/issues"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/types/server.d.ts",
      "import": "./dist/server.esm.js",
      "require": "./dist/server.js"
    }
  },
  "scripts": {
    "dev": "./build.js --watch",
    "prebuild": "rm -rf dist",
    "build": "./build.js",
    "postbuild": "tsc --emitDeclarationOnly",
    "prepublish": "pnpm build"
  },
  "dependencies": {
    "@inertiajs/core": "^2.3.21",
    "@solid-primitives/deep": "^0.3.5",
    "@solid-primitives/memo": "^1.4.5",
    "es-toolkit": "^1.46.1",
    "laravel-precognition": "^1.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.31.0",
    "@solidjs/meta": "^0.29.4",
    "esbuild": "^0.25.12",
    "esbuild-node-externals": "^1.22.0",
    "solid-js": "^1.9.13",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@solidjs/meta": "^0.29.4",
    "solid-js": "^1.9.13"
  }
}
