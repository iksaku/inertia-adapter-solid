{
  "compilerOptions": {
    "rootDir": "src",
    "noEmitOnError": true,

    "lib": ["DOM", "DOM.Iterable", "es2022"],
    "target": "es2022",

    "declaration": true,
    "declarationDir": "types",
    "emitDeclarationOnly": true,

    "module": "es2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,

    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  },
  "include": ["src/index.ts", "src/server.ts", "src/vite.ts"]
}
